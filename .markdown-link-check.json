{
  "ignorePatterns": [
    {
      "pattern": "^https://private"
    },
    {
      "pattern": "^https://localhost"
    },
    {
      "pattern": "^https://127\\.0\\.0\\.1"
    },
    {
      "pattern": "^mailto:"
    }
  ],
  "replacementPatterns": [
    {
      "pattern": "%20",
      "replacement": " ",
      "global": true
    }
  ],
  "httpHeaders": [],
  "timeout": "15s",
  "retryOn429": true,
  "retryCount": 3,
  "fallbackRetryDelay": "5s",
  "aliveStatusCodes": [200, 206, 301, 302, 307, 308]
}